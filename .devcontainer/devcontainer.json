// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
	"name": "Herve RISC-V Dev",
	// Use a Dockerfile for faster, reproducible builds with pre-cached layers
	"build": {
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/veryl-lang/devcontainer-features/verilator:1": {},
		"ghcr.io/devcontainers-extra/features/pipenv:2": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"saoudrizwan.claude-dev",
				"mshr-h.veriloghdl"
			]
		}
	},
	// Pre-warm apt cache to speed up postCreateCommand
	"onCreateCommand": "sudo apt-get update -qq",
	// Install all dependencies in parallel after container creation
	"postCreateCommand": "sudo apt-get install -y -qq gcc-riscv64-linux-gnu g++-riscv64-linux-gnu binutils-riscv64-linux-gnu gcc-riscv64-unknown-elf iverilog device-tree-compiler git build-essential autoconf automake autotools-dev libmpc-dev libmpfr-dev libgmp-dev gawk bison flex texinfo libtool patchutils bc zlib1g-dev libexpat1-dev && echo 'Dependencies installed'",
	// Set RISCV toolchain path
	"containerEnv": {
		"RISCV": "/opt/riscv",
		"PATH": "/opt/riscv/bin:${containerEnv:PATH}"
	},
	// Mount apt cache for faster rebuilds
	"mounts": [
		"source=herve-apt-cache,target=/var/cache/apt,type=volume",
		"source=herve-apt-lib,target=/var/lib/apt/lists,type=volume"
	],
	// Use 100% of available CPUs for builds
	"remoteEnv": {
		"NPROC": "${containerEnv:NPROC:-$(nproc)}",
		"MAKEFLAGS": "-j$(nproc)"
	}
}
